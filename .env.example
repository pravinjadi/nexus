# ─── Database ─────────────────────────────────────────────────────────────────
# Get a free PostgreSQL URL from https://supabase.com or https://neon.tech
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexus?sslmode=require"

# ─── NextAuth ─────────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET="replace-with-random-secret"

# ─── Google OAuth ─────────────────────────────────────────────────────────────
# Create at: https://console.cloud.google.com → APIs & Services → Credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID="your-google-client-id.apps.googleusercontent.com"
AUTH_GOOGLE_SECRET="your-google-client-secret"

# ─── App URL ──────────────────────────────────────────────────────────────────
NEXTAUTH_URL="http://localhost:3000"
